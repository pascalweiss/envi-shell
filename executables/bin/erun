#!/usr/bin/env bash
#
# erun — run a command on a remote host that the USER already has an open,
# interactive ssh session to, by reusing that session's multiplexed master
# connection (see ~/.envi/integrations/ssh/config).
#
# The point: an AI agent (or any non-interactive shell) gets clean stdout,
# stderr and a real exit code from the remote host, WITHOUT any credentials of
# its own. It piggybacks on the connection you authenticated interactively, so
# it works for hosts the agent has never seen and has no key/password for
# (fresh k8s nodes, random servers behind a jump host, 2FA logins, ...).
#
# Usage:
#   erun --list                 list hosts you currently have ssh sessions to
#   erun <target> <cmd...>      run <cmd...> on <target>
#
# <target> is what you would pass to ssh (user@host, host, or a Host alias). It
# need not match the interactive session's spelling verbatim: if it resolves to
# the same host+user+port as an open session, erun reuses that master. Still,
# copying the target straight from `erun --list` is the surest.
#
# erun never prompts for a password: if no reusable session exists it fails fast
# with guidance instead of blocking. It passes the remote command's exit code
# straight through (a connection failure surfaces as 255).

set -o pipefail
prog=$(basename "$0")

# Print the header comment (usage) as help text.
_usage() {
    sed -n '3,29p' "$0" | sed 's/^#\{1,2\} \{0,1\}//; s/^#$//'
}

# List the user's interactive ssh CLIENT sessions by inspecting running
# processes and extracting each ssh invocation's target host. Best-effort:
# this is a discovery hint; execution correctness does not depend on it.
_list_targets() {
    ps -axo command= 2>/dev/null \
      | grep -E '(^|/)ssh( |$)' \
      | grep -vE 'ssh-agent|ssh-add|/sshd|[[:space:]]sshd|/erun|[[:space:]]-O[[:space:]]' \
      | while IFS= read -r line; do
            target=""
            # shellcheck disable=SC2086
            set -- $line
            while [ "$#" -gt 0 ]; do
                case "$1" in
                    ssh|*/ssh) : ;;                 # the binary itself
                    -o) shift ;;                    # skip "-o" and its value
                    -[bcDeFIiJLlmOopQRSWw]) shift ;; # option flags that take an argument
                    -*) : ;;                        # other flags (no argument)
                    *=*) : ;;                       # env-style tokens
                    *) target="$1" ;;               # candidate host (keep last)
                esac
                shift
            done
            [ -n "$target" ] && printf '%s\n' "$target"
        done | sort -u
}

# Resolve a host name to a comparable address, cross-platform and best-effort.
# Returns the name unchanged if it is already an IP literal; empty output means
# "could not resolve" and the caller then declines to match on it.
_resolve_ip() {
    name="$1"
    case "$name" in
        *:*) printf '%s\n' "$name"; return 0 ;;   # IPv6 literal
    esac
    case "$name" in
        *[!0-9.]*) : ;;                           # has non-[digit/dot] → a name
        *) printf '%s\n' "$name"; return 0 ;;     # pure digits/dots → IPv4 literal
    esac
    ip=""
    if command -v getent >/dev/null 2>&1; then   # Linux (glibc)
        ip=$(getent ahostsv4 "$name" 2>/dev/null | awk 'NR==1{print $1}')
        [ -z "$ip" ] && ip=$(getent hosts "$name" 2>/dev/null | awk 'NR==1{print $1}')
    fi
    if [ -z "$ip" ] && command -v dscacheutil >/dev/null 2>&1; then   # macOS
        ip=$(dscacheutil -q host -a name "$name" 2>/dev/null \
             | awk '/^ip_address:/{print $2; exit}')
    fi
    if [ -z "$ip" ] && command -v perl >/dev/null 2>&1; then          # portable fallback
        ip=$(perl -MSocket -e 'my @a=gethostbyname($ARGV[0]); print inet_ntoa($a[4]) if @a>4' \
             "$name" 2>/dev/null)
    fi
    printf '%s\n' "$ip"
}

# Canonical identity of a target as "ip|user|port", using the EFFECTIVE ssh
# config (so a Host alias and its underlying HostName compare equal). A leading
# "|" (empty ip) marks an unresolvable target the caller must not match on.
_canon_id() {
    cfg=$(ssh -G "$1" 2>/dev/null)
    h=$(printf '%s\n' "$cfg" | awk 'tolower($1)=="hostname"{print $2; exit}')
    u=$(printf '%s\n' "$cfg" | awk 'tolower($1)=="user"{print $2; exit}')
    p=$(printf '%s\n' "$cfg" | awk 'tolower($1)=="port"{print $2; exit}')
    printf '%s|%s|%s\n' "$(_resolve_ip "$h")" "$u" "$p"
}

case "${1:-}" in
    ""|-h|--help)
        _usage
        exit 0
        ;;
    -l|--list)
        targets=$(_list_targets)
        if [ -z "$targets" ]; then
            echo "$prog: no open ssh sessions found." >&2
            echo "Open one interactively first (e.g. in a tmux pane): ssh user@host" >&2
            exit 1
        fi
        echo "Open ssh sessions you can erun into:"
        printf '%s\n' "$targets" | while IFS= read -r h; do
            if ssh -o BatchMode=yes -O check "$h" >/dev/null 2>&1; then
                printf '  %-40s [master live, reusable]\n' "$h"
            else
                printf '  %-40s [no master — reopen the session]\n' "$h"
            fi
        done
        exit 0
        ;;
esac

target="$1"; shift
if [ "$#" -eq 0 ]; then
    echo "$prog: no command given." >&2
    echo "Usage: $prog <target> <cmd...>   (try: $prog --list)" >&2
    exit 2
fi

# Is a reusable master already live for this exact target? (fast, no auth)
have_master=false
ssh -o BatchMode=yes -O check "$target" >/dev/null 2>&1 && have_master=true

# Slow path: no master for the exact spelling. The session may have been opened
# under a different spelling of the same host (an IP vs a DNS name or alias).
# Match open sessions by canonical identity (resolved ip+user+port) and reuse
# the one that points at the same host, so `erun forum0` finds a master that was
# opened as `ssh 10.0.0.5`. Only runs on a miss, so the fast path pays nothing.
if [ "$have_master" = false ]; then
    want=$(_canon_id "$target")
    case "$want" in
        "|"*) : ;;   # target's host did not resolve → cannot match safely
        *)
            while IFS= read -r cand; do
                [ -z "$cand" ] && continue
                [ "$cand" = "$target" ] && continue
                if [ "$(_canon_id "$cand")" = "$want" ] \
                   && ssh -o BatchMode=yes -O check "$cand" >/dev/null 2>&1; then
                    echo "$prog: reusing open session '$cand' for '$target' (same host)." >&2
                    target="$cand"; have_master=true
                    break
                fi
            done <<EOF
$(_list_targets)
EOF
            ;;
    esac
fi

# BatchMode=yes: reuse the master if present; otherwise fail fast instead of
# hanging on a password prompt.
ssh -o BatchMode=yes "$target" "$@"
rc=$?

if [ "$rc" -eq 255 ] && [ "$have_master" = false ]; then
    {
        echo "$prog: cannot reach '$target' non-interactively (no reusable ssh session)."
        echo "Open an interactive session to it first, then retry:"
        echo "    ssh $target"
        echo "erun reuses that session's connection; it has no credentials of its own."
        echo "Tip: run '$prog --list' to see the exact target strings you can use."
    } >&2
fi
exit "$rc"
